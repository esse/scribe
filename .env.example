# Scribe is local-first: it runs on your machine with your own API keys, and
# everything stays under the data dir. Copy this to .env (gitignored):
#   cp .env.example .env
#
# The pipeline runs OFFLINE by default (stub transcription + fake LLM) so you can
# try the whole flow with zero keys and zero spend. Fill in keys below to use
# real services.

# --- Data directory (local-first) ---
# Everything persistent lives here: the SQLite database, recordings, frames, and
# the generated manual files. Mount this one folder into Docker to keep state.
SCRIBE_DATA_DIR=./data

# --- LLM provider (manual generation) ---
# anthropic = your own Anthropic API key (hosted Claude)
# local     = a local llama model over an OpenAI-compatible API (nothing leaves
#             the machine)
# fake      = offline deterministic stub (no model, no spend)
# Defaults to "anthropic" if ANTHROPIC_API_KEY is set, otherwise "fake".
LLM_PROVIDER=

# Anthropic (hosted Claude) — your own key.
ANTHROPIC_API_KEY=
ANTHROPIC_MANUAL_MODEL=claude-sonnet-4-6
ANTHROPIC_CAPTION_MODEL=claude-haiku-4-5-20251001

# Local llama model (LLM_PROVIDER=local). Point at any OpenAI-compatible server:
#   • Ollama:       http://localhost:11434/v1   (run `ollama serve`)
#   • llama.cpp:    http://localhost:8080/v1
#   • LM Studio:    http://localhost:1234/v1
# Use a VISION-capable model so it can read the screenshots.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2-vision
LLM_API_KEY=

CLAUDE_MAX_IMAGES=25
CLAUDE_CHUNK_SECONDS=600

# --- Transcription / STT ---
# whisper (local CLI, default — audio never leaves the machine) | deepgram |
# openai (hosted, need a key) | stub (offline, no real transcription)
TRANSCRIPTION_PROVIDER=whisper
# Local STT: a CLI that emits JSON with segments[].start/end/text
# (e.g. a faster-whisper / whisper-ctranslate2 wrapper). See README.
WHISPER_BIN=faster-whisper
# Hosted alternatives (optional):
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Frames ---
SCENE_THRESHOLD=0.4
THUMBNAIL_MAX_EDGE=768
FRAME_FALLBACK_SECONDS=20
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- PDF export ---
# WeasyPrint CLI (HTML/CSS → PDF). "weasyprint" if on PATH, or "python3 -m weasyprint".
WEASYPRINT_CMD=weasyprint

# --- Result files ---
# Write each finished manual out as plain files (manual.json/md/html/pdf) under
# the data dir. Set to "false" to keep results only in the database.
WRITE_RESULT_FILES=true

# --- Retention ---
# Days to keep raw videos before auto-purge. 0 = keep everything (default).
RAW_VIDEO_RETENTION_DAYS=0

# --- Storage / uploads (under the data dir by default) ---
# STORAGE_ROOT=./data/storage
# TUS_DATA_DIR=./data/tus
SIGNED_URL_TTL=900
TUS_MAX_SIZE=5368709120

# --- Production / Docker only ---
# Required when running in production (e.g. the Docker image). Generate with
# `openssl rand -hex 32`. Not needed for local `bin/dev` development.
SECRET_KEY_BASE=
# Set to "true" only when running behind an HTTPS reverse proxy.
FORCE_SSL=
