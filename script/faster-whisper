#!/usr/bin/env python3
"""Local Whisper transcription wrapper for Scribe.

`Transcription::Whisper` shells out to a CLI like:

    faster-whisper --output_format json --language auto <audio_path>

and parses JSON from stdout with {language, text, segments:[{start,end,text}]}
(start/end in seconds). Real Whisper CLIs write files instead of stdout, so this
thin wrapper around the faster-whisper Python library produces exactly that
shape on stdout. It runs fully offline using a pre-downloaded model.

Configurable via env:
  WHISPER_MODEL        model size/name (default "base")
  WHISPER_DEVICE       "cpu" (default) or "cuda"
  WHISPER_COMPUTE_TYPE ctranslate2 compute type (default "int8")
  WHISPER_MODEL_DIR    where models are cached / pre-downloaded
"""
import json
import os
import sys

from faster_whisper import WhisperModel


def main():
    args = sys.argv[1:]
    if not args:
        sys.stderr.write("usage: faster-whisper [--language LANG] <audio_path>\n")
        return 2

    audio_path = args[-1]

    language = None
    if "--language" in args:
        value = args[args.index("--language") + 1]
        if value and value != "auto":
            language = value

    # Treat blank env values as unset so an empty override never breaks defaults.
    model_name = os.environ.get("WHISPER_MODEL") or "base"
    device = os.environ.get("WHISPER_DEVICE") or "cpu"
    compute_type = os.environ.get("WHISPER_COMPUTE_TYPE") or "int8"
    download_root = os.environ.get("WHISPER_MODEL_DIR") or None

    model = WhisperModel(
        model_name, device=device, compute_type=compute_type, download_root=download_root
    )
    segments, info = model.transcribe(audio_path, language=language)

    seg_list = []
    texts = []
    for segment in segments:
        text = segment.text.strip()
        seg_list.append({"start": segment.start, "end": segment.end, "text": text})
        texts.append(text)

    json.dump(
        {
            "language": getattr(info, "language", None) or "en",
            "text": " ".join(texts).strip(),
            "segments": seg_list,
        },
        sys.stdout,
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
