#!/usr/bin/env bash
# Provisions a Claude Code (web) session so tests/linters can run:
# ensures ffmpeg, a running Postgres with a `root` role, gems, and the test DB.
# Idempotent and best-effort — never fails the session start.
set -uo pipefail

log() { echo "[web-setup] $*"; }

# Make rbenv/gem shims available.
if command -v ruby >/dev/null 2>&1; then
  export PATH="$PATH:$(ruby -e 'print Gem.bindir' 2>/dev/null)"
fi

# ffmpeg/ffprobe (media pipeline, SPEC §8).
if ! command -v ffmpeg >/dev/null 2>&1; then
  log "installing ffmpeg"
  (apt-get install -y ffmpeg >/dev/null 2>&1 || sudo apt-get install -y ffmpeg >/dev/null 2>&1) \
    && log "ffmpeg installed" || log "could not install ffmpeg (continuing)"
fi

# Postgres.
if command -v pg_ctlcluster >/dev/null 2>&1; then
  if ! pg_isready >/dev/null 2>&1; then
    log "starting postgres"
    (pg_ctlcluster 16 main start >/dev/null 2>&1 || service postgresql start >/dev/null 2>&1) || true
    sleep 2
  fi
  # A login role matching the app's default credentials.
  sudo -u postgres psql -tc "SELECT 1 FROM pg_roles WHERE rolname='root'" 2>/dev/null | grep -q 1 \
    || sudo -u postgres psql -c "CREATE ROLE root WITH LOGIN SUPERUSER PASSWORD 'postgres';" >/dev/null 2>&1 || true
fi

# Gems + test database.
if [ -f Gemfile ]; then
  log "installing gems"
  bundle install --quiet 2>/dev/null || true
  log "preparing test database"
  RAILS_ENV=test bin/rails db:test:prepare 2>/dev/null || true
fi

log "ready"
exit 0
