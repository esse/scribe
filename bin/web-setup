#!/usr/bin/env bash
# Provisions a Claude Code (web) session so tests/linters can run: ensures
# ffmpeg + WeasyPrint, installs gems, and prepares the SQLite databases.
# Local-first: SQLite needs no server, so there's no Postgres/MinIO to start.
# Idempotent and best-effort — never fails the session start.
set -uo pipefail

log() { echo "[web-setup] $*"; }

# Make rbenv/gem shims available.
if command -v ruby >/dev/null 2>&1; then
  export PATH="$PATH:$(ruby -e 'print Gem.bindir' 2>/dev/null)"
fi

# ffmpeg/ffprobe (media pipeline, SPEC §8).
if ! command -v ffmpeg >/dev/null 2>&1; then
  log "installing ffmpeg"
  (apt-get install -y ffmpeg >/dev/null 2>&1 || sudo apt-get install -y ffmpeg >/dev/null 2>&1) \
    && log "ffmpeg installed" || log "could not install ffmpeg (continuing)"
fi

# WeasyPrint for PDF export (SPEC §11.2).
if ! command -v weasyprint >/dev/null 2>&1; then
  log "installing weasyprint"
  (apt-get install -y weasyprint >/dev/null 2>&1 || sudo apt-get install -y weasyprint >/dev/null 2>&1) \
    && log "weasyprint installed" || log "could not install weasyprint (PDF export will be unavailable)"
fi

# Gems + SQLite databases (under ./data; no DB server required).
if [ -f Gemfile ]; then
  log "installing gems"
  bundle install --quiet 2>/dev/null || true
  log "preparing databases"
  bin/rails db:prepare 2>/dev/null || true          # development (primary + queue)
  RAILS_ENV=test bin/rails db:test:prepare 2>/dev/null || true
fi

log "ready"
exit 0
