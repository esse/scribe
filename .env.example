# Scribe environment variables. Copy to .env (gitignored) for local development:
#   cp .env.example .env
# All secrets are server-side only — none of these reach the browser (SPEC §5).
#
# ── To test the WHOLE flow locally (real transcription + manual generation) ──
#   1. docker compose up -d            # Postgres + MinIO (+ creates the bucket)
#   2. Fill in ANTHROPIC_API_KEY below.
#   3. Pick a transcription provider:
#        • TRANSCRIPTION_PROVIDER=deepgram + DEEPGRAM_API_KEY   (hosted, easiest)
#        • TRANSCRIPTION_PROVIDER=whisper  + WHISPER_BIN        (fully local, no key)
#   4. Set STORAGE_ADAPTER=s3 (MinIO settings below are pre-filled).
#   5. bin/rails db:prepare && bin/dev   then open http://localhost:3000
# Leave the AI keys blank to run the pipeline offline with deterministic stubs.

# --- Database (matches docker-compose.yml) ---
PGHOST=localhost
PGPORT=5432
PGUSER=root
PGPASSWORD=postgres

# --- AI: Anthropic (SPEC §9) ---
# Leave ANTHROPIC_API_KEY blank to use the offline fake client (no spend).
ANTHROPIC_API_KEY=
ANTHROPIC_MANUAL_MODEL=claude-sonnet-4-6
ANTHROPIC_CAPTION_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_IMAGES=25
CLAUDE_CHUNK_SECONDS=600

# --- Transcription / STT (SPEC §9.3) ---
# stub (offline default) | deepgram (hosted, needs key) | whisper (local CLI)
TRANSCRIPTION_PROVIDER=stub
DEEPGRAM_API_KEY=
# Local STT: a CLI that emits JSON with `segments[].start/end/text` (e.g. a
# faster-whisper / whisper-ctranslate2 wrapper). See README.
WHISPER_BIN=faster-whisper

# --- Frames (SPEC §8.4) ---
SCENE_THRESHOLD=0.4
THUMBNAIL_MAX_EDGE=768
FRAME_FALLBACK_SECONDS=20
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- PDF export (SPEC §11.2) ---
# WeasyPrint CLI (HTML/CSS → PDF). "weasyprint" if on PATH, or "python3 -m weasyprint".
WEASYPRINT_CMD=weasyprint

# --- Credits / metering (SPEC §13.3) ---
CREDITS_PER_MINUTE=1

# --- Retention (SPEC §14) ---
RAW_VIDEO_RETENTION_DAYS=30

# --- Object storage (SPEC §4, §5) ---
# disk (no setup) | s3 (MinIO locally, R2/S3 in prod). Use s3 to exercise signed URLs.
STORAGE_ADAPTER=disk
STORAGE_BUCKET=scribe
STORAGE_ROOT=tmp/storage
SIGNED_URL_TTL=900
# MinIO defaults (from docker-compose.yml). Only used when STORAGE_ADAPTER=s3.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Server-side encryption: "AES256" for real S3/R2; leave blank for MinIO dev.
S3_SSE=

# --- Resumable upload (SPEC §7.2) ---
TUS_DATA_DIR=tmp/tus-data
TUS_MAX_SIZE=5368709120

# --- Stripe (SPEC §12) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/credits?status=success
STRIPE_CANCEL_URL=http://localhost:3000/credits?status=cancel

# --- Observability (SPEC §15) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
