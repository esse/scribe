<% content_for :title, "Record" %>

<section data-controller="recorder">
  <h1>Record your screen</h1>
  <p class="muted">
    Capture your screen with narration. We transcribe the audio, pull aligned
    screenshots, and have Claude write a step-by-step manual. Desktop Chromium or
    Firefox only — screen capture isn't available on mobile Safari.
  </p>

  <label class="toggle">
    <input type="checkbox" data-recorder-target="systemAudio">
    Include system/tab audio (Chromium only). Default captures the microphone.
  </label>

  <div class="controls">
    <button data-recorder-target="start" data-action="recorder#start">Start recording</button>
    <button data-recorder-target="stop" data-action="recorder#stop" disabled>Stop &amp; upload</button>
  </div>

  <p class="status" data-recorder-target="status" aria-live="polite">Ready.</p>

  <p class="muted small">
    Recording requires a secure (HTTPS) context and a user gesture. You'll be
    prompted to choose a screen and grant microphone access.
  </p>
</section>

<section class="existing-upload">
  <h2>Or use a recording you already have</h2>
  <p class="muted">
    Already captured a screen recording? Upload it (webm, mp4, mov, mkv) and
    Scribe runs the same pipeline — no live capture needed. You can also do this
    from the command line: <code>bin/rails "scribe:ingest[/path/to/video.mp4]"</code>.
  </p>
  <%= form_with url: upload_recordings_path, method: :post, multipart: true do |f| %>
    <%= f.file_field :file, accept: "video/*", required: true %>
    <%= f.submit "Upload & process" %>
  <% end %>
</section>
